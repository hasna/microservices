# @hasna/microservices — Environment Variables Example

# ==============================================================================
# REQUIRED
# ==============================================================================
# The core database used by all microservices
DATABASE_URL="postgres://postgres:password@localhost:5432/microservices"

# The core signing secret for JWTs (Auth service)
JWT_SECRET="super-secret-local-development-key-change-me"


# ==============================================================================
# OPTIONAL INTEGRATIONS
# ==============================================================================

# -- Identity & Auth --
# OAuth Providers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -- Artificial Intelligence --
# Providers for the LLM, Knowledge, and Memory services
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""

# -- Storage (Files Service) --
# Set to 's3' to use AWS/S3-compatible storage. Defaults to 'local'.
FILES_STORAGE="local"
FILES_LOCAL_DIR="./uploads"

S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# -- Billing (Stripe) --
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# -- Communications (Notify Service) --
# Email
RESEND_API_KEY=""
SMTP_HOST=""
NOTIFY_FROM_EMAIL="noreply@example.com"

# SMS
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""


# ==============================================================================
# CUSTOM PORTS (Overrides)
# ==============================================================================
# Each service defaults to a specific port in the 3000-range, but you can override them here:
# AUTH_PORT=3000
# TEAMS_PORT=3002
# BILLING_PORT=3003
# NOTIFY_PORT=3004
# FILES_PORT=3005
# AUDIT_PORT=3006
# FLAGS_PORT=3007
# JOBS_PORT=3008
# LLM_PORT=3009
# MEMORY_PORT=3010
# SEARCH_PORT=3011
# KNOWLEDGE_PORT=3012
# SESSIONS_PORT=3013
# GUARDRAILS_PORT=3014
# AGENTS_PORT=3015
# PROMPTS_PORT=3016
# TRACES_PORT=3017
# USAGE_PORT=3018
# WAITLIST_PORT=3019
# ONBOARDING_PORT=3020
# WEBHOOKS_PORT=3021
