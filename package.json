{
  "name": "@hasna/microservices",
  "version": "0.0.10",
  "description": "Mini business apps for AI agents - invoices, contacts, bookkeeping and more, each with its own SQLite database",
  "type": "module",
  "bin": {
    "microservices": "./bin/index.js",
    "microservices-mcp": "./bin/mcp.js"
  },
  "files": [
    "bin/",
    "dist/",
    "microservices/",
    "!microservices/**/node_modules",
    "!microservices/**/bun.lock",
    "!microservices/**/*.test.ts",
    "!microservices/**/dashboard/node_modules",
    "!microservices/**/dashboard/src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun build ./src/cli/index.tsx --outdir ./bin --target bun --external ink --external react --external chalk --external conf && bun build ./src/mcp/index.ts --outfile ./bin/mcp.js --target bun && bun build ./src/index.ts --outdir ./dist --target bun",
    "dev": "bun run ./src/cli/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "microservices",
    "ai",
    "agent",
    "sqlite",
    "invoices",
    "contacts",
    "bookkeeping",
    "cli",
    "mcp",
    "model-context-protocol"
  ],
  "author": "Hasna",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.2.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.2.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hasna/microservices.git"
  },
  "homepage": "https://github.com/hasna/microservices#readme",
  "bugs": {
    "url": "https://github.com/hasna/microservices/issues"
  }
}
